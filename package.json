{
  "name": "ghcr-manager",
  "version": "0.0.0",
  "private": true,
  "description": "Inspect, analyze, and manage GitHub Container Registry packages.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "ghcr-manager": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "ghcr-manager": "tsx src/cli.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run typecheck && npm run lint:ts && npm run lint:yaml && npm run lint:markdown && npm run format:check",
    "lint:ts": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:yaml": "eslint \".github/**/*.yml\" \"*.yml\"",
    "lint:markdown": "markdownlint-cli2",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "node --import tsx --test"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-yml": "^1.18.0",
    "globals": "^16.4.0",
    "markdownlint-cli2": "^0.18.1",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript-eslint": "^8.46.2",
    "typescript": "^5.8.3"
  }
}
